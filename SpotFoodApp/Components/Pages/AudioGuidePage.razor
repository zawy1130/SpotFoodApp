@* @page "/"
@inject IJSRuntime JS
@inject HttpClient Http
@inject SpotFoodApp.Service.LocationService LocationService
@using SpotFoodApp.DTO

<div class="page">

    <div class="header">
        <h4>Phố ẩm thực Vĩnh Khánh</h4>
    </div>

    <!-- CATEGORY -->
    <div class="category-bar">
        @foreach (var c in Categories)
        {
            <div class="category @(c.CategoryId == SelectedCategory ? "active" : "")"
                 @onclick="() => SelectCategory(c.CategoryId)">
                @c.CategoryName
            </div>
        }
    </div>

    <!-- MAP -->
    <div class="map-container">
        <div id="map"></div>

        <button class="btn-location" @onclick="GoToMyLocation">
            📍
        </button>
    </div>

    <!-- BOTTOM SHEET -->
    <div class="bottom-sheet">
        <div class="poi-list">
            @foreach (var item in FilteredPoi)
            {
                <div class="poi-card" @onclick="() => FocusPoi(item)">
                    <div class="info">
                        <div class="name">@item.Name</div>
                        <div class="distance">
                            @(item.Distance < 1000
                                ? $"{item.Distance} m"
                                : $"{(item.Distance / 1000.0):0.0} km")
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    List<CategoryDto> Categories = new();
    List<PoiDto> PoiList = new();           // Danh sách POI gần nhất (dùng cho bottom sheet)

    int SelectedCategory = 0;

    // Bottom sheet luôn hiển thị POI gần nhất (chỉ lọc category khi cần)
    IEnumerable<PoiDto> FilteredPoi =>
        PoiList
            .Where(p => SelectedCategory == 0 || p.CategoryId == SelectedCategory)
            .OrderBy(p => p.Distance)
            .Take(10);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initMap");

            // Load categories
            Categories = await Http.GetFromJsonAsync<List<CategoryDto>>(http://192.168.2.43:5205/api/categories")
                         ?? new List<CategoryDto>();

            Categories.Insert(0, new CategoryDto
            {
                CategoryId = 0,
                CategoryName = "Tất cả"
            });

            // Bắt đầu theo dõi vị trí người dùng
            await LocationService.StartListening(async (loc) =>
            {
                // Cập nhật vị trí user trên map
                await JS.InvokeVoidAsync("updateUserLocation", loc.Latitude, loc.Longitude);

                // Load POI gần vị trí hiện tại
                await LoadPOI(loc.Latitude, loc.Longitude);
            });
        }
    }

    async Task LoadPOI(double lat, double lng)
    {
        var pois = await Http.GetFromJsonAsync<List<PoiDto>>(
            $"http://192.168.2.43:5205/api/pois/nearby?lat={lat}&lng={lng}&radius=1000"); // tăng radius nếu cần

        if (pois == null) return;

        // Tính khoảng cách
        foreach (var p in pois)
        {
            p.Distance = CalculateDistance(lat, lng, p.Latitude, p.Longitude);
        }

        PoiList = pois.OrderBy(p => p.Distance).ToList();

        StateHasChanged();

        // Gửi toàn bộ POI lên JavaScript để hiển thị marker
        await JS.InvokeVoidAsync("showPOIs", PoiList);
    }

    async Task SelectCategory(int id)
    {
        SelectedCategory = id;
        await JS.InvokeVoidAsync("filterMarkers", id);   // chỉ lọc marker trên map
        StateHasChanged(); // refresh bottom sheet
    }

    async Task FocusPoi(PoiDto poi)
    {
        await JS.InvokeVoidAsync("focusToPoi", poi.Latitude, poi.Longitude);
    }

    async Task GoToMyLocation()
    {
        await JS.InvokeVoidAsync("goToMyLocation");
    }

    double CalculateDistance(double lat1, double lon1, double lat2, double lon2)
    {
        var R = 6371e3; // mét
        var φ1 = lat1 * Math.PI / 180;
        var φ2 = lat2 * Math.PI / 180;
        var Δφ = (lat2 - lat1) * Math.PI / 180;
        var Δλ = (lon2 - lon1) * Math.PI / 180;

        var a = Math.Sin(Δφ / 2) * Math.Sin(Δφ / 2) +
                Math.Cos(φ1) * Math.Cos(φ2) *
                Math.Sin(Δλ / 2) * Math.Sin(Δλ / 2);

        var c = 2 * Math.Atan2(Math.Sqrt(a), Math.Sqrt(1 - a));

        return Math.Round(R * c);
    }
} *@